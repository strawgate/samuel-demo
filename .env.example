# Vertex AI (Google Cloud)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/vertex-service-token.json
VERTEX_MODEL=gemini-2.5-flash

# Admin auth (simple token-based)
ADMIN_TOKEN=change-me-to-a-secure-token

# Postgres (local in container)
DATABASE_URL=postgresql://piestore:piestore@localhost:5432/piestore

# App
PUBLIC_BASE_URL=http://localhost:8000

# Logfire AI Gateway (optional - for DLP modes)
VERTEX_ENDPOINT_ENFORCE=
VERTEX_ENDPOINT_OBSERVE=
VERTEX_API_KEY=
