# Pydantic AI Gateway
MODEL=gateway/google-cloud:gemini-2.5-flash
PYDANTIC_AI_GATEWAY_API_KEY=your-gateway-api-key-here

# Admin auth (simple token-based)
ADMIN_TOKEN=change-me-to-a-secure-token

# Postgres (local in container)
DATABASE_URL=postgresql://piestore:piestore@localhost:5432/piestore

# App
PUBLIC_BASE_URL=http://localhost:8080
